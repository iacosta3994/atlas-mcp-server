{
  "name": "atlas-mcp-server",
  "version": "1.0.0",
  "description": "MCP (Model Context Protocol) server for Atlas Monolith Agent integration with SSE transport",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "vercel dev",
    "build": "tsc",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "deploy": "vercel --prod"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "atlas",
    "sse",
    "server-sent-events",
    "json-rpc",
    "vercel"
  ],
  "author": "Ian Acosta",
  "license": "MIT",
  "dependencies": {
    "@types/node": "^20.11.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3",
    "vercel": "^33.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
